HTTP_PORT=8093

# Public site details (used for FixMyStreet URL generation + email domains)
BASE_URL=http://www.kenyawewant.com
EMAIL_DOMAIN=kenyawewant.com
CONTACT_EMAIL=help@kenyawewant.com
CONTACT_NAME=FixMyStreet
DO_NOT_REPLY_EMAIL=help@kenyawewant.com

# Postgres credentials
POSTGRES_PASSWORD=password
FMS_DB_HOST=postgres.svc
FMS_DB_PORT=5432
FMS_DB_NAME=fixmystreet
FMS_DB_USER=fms
FMS_DB_PASS=fms

# FixMyStreet container settings
FMS_ROOT=/var/www/fixmystreet/fixmystreet
SUPERUSER_EMAIL=superuser@kenyawewant.com
SUPERUSER_PASSWORD=change_me_now

# general.yml renderer inputs
STAGING_SITE=0
STAGING_FLAGS_SEND_REPORTS=0
STAGING_FLAGS_SKIP_CHECKS=0
STAGING_FLAGS_HIDE_STAGING_BANNER=0

# MapIt (leave empty to use the default fallback areas)
MAPIT_URL=
MAPIT_TYPES=[ 'ZZZ' ]

# Mail settings
SMTP_SMARTHOST=localhost
SMTP_TYPE=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=

MEMCACHED_HOST=memcached.svc
CACHE_TIMEOUT=3600
QUEUE_DAEMON_PROCESSES=4

# Which cobrand(s) FixMyStreet should allow.
ALLOWED_COBRANDS=[ 'default' ]